# Mapbox — get a free token at https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here

# Google Gemini — get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Redis — default works if running locally, update for Vultr deployment
REDIS_URL=redis://localhost:6379

MONGODB_URI=mongodb://localhost:27017/vigil
JWT_SECRET=change_this_to_a_random_string

# GNews API — free tier (100 req/day), get a key at https://gnews.io
GNEWS_API_KEY=your_gnews_api_key_here
